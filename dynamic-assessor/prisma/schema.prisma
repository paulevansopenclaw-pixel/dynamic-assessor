datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Module {
  id               String     @id @default(cuid())
  name             String
  complianceAnchor String
  scenarios        Scenario[]
  createdAt        DateTime   @default(now())
}

model Scenario {
  id                 String   @id @default(cuid())
  symptoms           String   // Storing JSON string array for simplicity in SQLite
  diagnosticQuestion String
  branches           String   // Storing JSON mapping for simplicity
  moduleId           String
  module             Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
}
